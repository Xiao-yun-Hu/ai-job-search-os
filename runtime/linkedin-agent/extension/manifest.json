{
  "manifest_version": 3,
  "name": "JobPilot",
  "version": "0.2.0",
  "description": "Rank LinkedIn jobs by resume fit and automate Easy Apply — configurable AI model, human confirmation before every submit.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.zhipin.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.zhipin.com/job_detail/*",
        "https://www.zhipin.com/web/geek/job*"
      ],
      "js": ["schema.js", "scorer.js", "storage.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobPilot"
  }
}
